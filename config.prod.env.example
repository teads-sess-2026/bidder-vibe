# Prod mode: bidder connects to the always-on AWS backing services instead of
# local Docker containers. Fill VM_HOST/DB_PASSWORD from Terraform outputs:
#
#   cd ../infra/terraform
#   VM_HOST=$(tofu output -raw vm_public_ip)
#   DB_PASSWORD=$(tofu output -raw db_password)
#
# then substitute below. Your machine must be in the Terraform
# data_ingress_cidrs allowlist to reach these ports.
# Copy to config.prod.env (gitignored) and run: make run-prod

DB_HOST=REPLACE_VM_HOST
DB_PORT=5432
DB_USER=bidder
DB_PASSWORD=REPLACE_DB_PASSWORD
REDIS_HOST=REPLACE_VM_HOST
REDIS_PORT=6379
SPRING_KAFKA_BOOTSTRAP_SERVERS=REPLACE_VM_HOST:9092

# bidder.timeout-ms guards biddingService.bid()'s own DB+Redis round trips.
# The 100 default assumes same-host Docker (<1ms). Over the WAN to AWS, a
# single Postgres round trip alone is ~40ms and bid() makes several, so the
# default causes "BID TIMEOUT" on most requests. SSP's own BIDDER_TIMEOUT_SECONDS
# (2s, see ssp/.env.prod) bounds the outer HTTP call, so there's headroom.
BIDDER_TIMEOUT_MS=200

# Command timeout for the Lettuce Redis client + its connection pool's max-wait
# (see spring.data.redis.timeout / lettuce.pool.max-wait in application.properties).
# The 200ms default assumes same-host Docker; over the WAN to AWS a round trip is
# ~40ms and can spike under load, so give it more headroom here too.
REDIS_TIMEOUT_MS=100

# /api/bid itself reads from in-memory cache + Redis (no DB round trip); this pool
# backs the async BidRecordBuffer flush and the Kafka win-notice consumer. SSP now
# targets up to 100000 RPS across all bidders (see ssp/.env.prod TARGET_RPS), so
# give the async paths more headroom than the previous default of 10.
# NOTE: Postgres is shared across every bidder team on the AWS VM — this pool size
# is per-bidder-process, so raise cautiously relative to Postgres max_connections.
R2DBC_POOL_MAX_SIZE=50
R2DBC_POOL_MIN_SIZE=20
