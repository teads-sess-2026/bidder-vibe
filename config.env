# Bidder identity (must match bidder.id in application.properties AND id in ssp/bidders.json)
BIDDER_ID=<team-name>

# HTTP endpoint the SSP calls to POST /api/bid. SSP and every bidder run on the
# same local network, so this is just your machine's local address — no public
# tunnel needed.
BIDDER_ENDPOINT_URL=http://localhost:8080
