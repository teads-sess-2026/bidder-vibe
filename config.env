# ── Bidder configuration ──────────────────────────────────────────────────────
# Edit when ngrok URLs change or switching environments.


# Bidder identity (must match bidder.id in application.properties AND id in ssp/bidders.json)
BIDDER_ID=my-team

# Bidder HTTP endpoint (ngrok URL when running locally with tunnel)
BIDDER_ENDPOINT_URL=http://localhost:8080

# Kafka — use localhost:9092 for local dev, or 100.x.x.x:9093 when connecting via Tailscale
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Tailscale IP of the SSP machine (only needed on this machine if running infra here)
TAILSCALE_IP=100.104.247.47
